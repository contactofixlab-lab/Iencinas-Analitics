# ─────────────────────────────────────────────────────────────
#  Iencinas Analytics — variables de entorno
#  Copia este archivo a `.env.local` y completa los valores.
# ─────────────────────────────────────────────────────────────

# Fuente de datos activa: "mock" (demo, por defecto) o "crm" (CRM real)
DATA_SOURCE=mock

# ── Conexión al CRM de ventas (necesario cuando DATA_SOURCE=crm) ──
CRM_API_BASE_URL=
CRM_API_KEY=

# Cómo se envía la API key:
#   bearer  → Authorization: Bearer <key>   (por defecto)
#   header  → <CRM_API_KEY_HEADER>: <key>
CRM_API_AUTH_SCHEME=bearer
CRM_API_KEY_HEADER=x-api-key

# Timeout de las llamadas al CRM (milisegundos)
CRM_API_TIMEOUT_MS=10000

# Si el CRM falla o no está configurado, usar datos mock para no dejar el
# dashboard en blanco. Ponlo en "false" para ver el error real al integrar.
CRM_FALLBACK_TO_MOCK=true
